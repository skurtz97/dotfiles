[Unit]
Description=Ollama Service
After=network-online.target

[Service]
ExecStart=/home/skurtz/src/ollama/ollama serve
# Ensure the working directory is the folder containing the binary
WorkingDirectory=/home/skurtz/src/ollama
# Inject the ROCm/RDNA 4 overrides
Environment="HSA_OVERRIDE_GFX_VERSION=12.0.1"
Environment="LD_LIBRARY_PATH=/opt/rocm-7.2.0/lib"

Restart=always
RestartSec=3


[Install]
WantedBy=default.target